# JobHuntr environment variables
# Copy to .env in the project root and fill in real values.

# PostgreSQL connection string (required)
# Format: postgres://user:password@host:5432/dbname?sslmode=disable
DATABASE_URL=postgres://jobhuntr:secret@localhost:5432/jobhuntr?sslmode=disable

# Anthropic Claude API key (required for resume/cover letter generation)
ANTHROPIC_API_KEY=sk-ant-...

# SerpAPI key (required for Google Jobs scraping)
SERPAPI_KEY=...

# ntfy.sh topic (required for push notifications)
NTFY_TOPIC=jobhuntr-yourname

# Session secret for cookie encryption (required; generate with: openssl rand -base64 32)
SESSION_SECRET=

# Google OAuth 2.0 credentials (optional; omit to disable Google login)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth credentials (optional; omit to disable GitHub login)
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

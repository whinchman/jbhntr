server:
  port: 8080
  base_url: "http://localhost:8080"

auth:
  session_secret: "${SESSION_SECRET}"  # 32+ byte random key; generate with: openssl rand -base64 32
  providers:
    google:
      client_id: "${GOOGLE_CLIENT_ID}"
      client_secret: "${GOOGLE_CLIENT_SECRET}"
    github:
      client_id: "${GITHUB_CLIENT_ID}"
      client_secret: "${GITHUB_CLIENT_SECRET}"

database:
  url: "${DATABASE_URL}"  # PostgreSQL DSN, e.g.: postgres://user:pass@localhost:5432/jobhuntr?sslmode=disable

scraper:
  interval: "1h"
  serpapi_key: "${SERPAPI_KEY}"
  jsearch_key: "${JSEARCH_KEY}"         # RapidAPI key for JSearch (jsearch.p.rapidapi.com)
  enabled_sources:                      # optional; omit to enable all configured sources
    - serpapi
    - jsearch

# DEPRECATED: search_filters is no longer used at runtime. Per-user search
# filters are configured in the web UI (Settings page) and stored in the
# database. This section is kept for reference only.
# search_filters:
#   - keywords: "senior software engineer golang"
#     location: "Remote"
#     min_salary: 150000

ntfy:
  server: "https://ntfy.sh"
  # Per-user ntfy topics are configured in the Settings page and stored in the database.

claude:
  api_key: "${ANTHROPIC_API_KEY}"
  model: "claude-sonnet-4-20250514"

output:
  dir: "./output"

admin:
  password: "${ADMIN_PASSWORD}"  # HTTP Basic Auth password for /admin panel; username is "admin"

# google_drive is optional. When client_id is empty the Drive integration is
# disabled and no Drive routes are registered. Register a project at
# https://console.cloud.google.com/ and enable the Google Drive API to obtain
# credentials.
google_drive:
  client_id: "${GOOGLE_DRIVE_CLIENT_ID}"
  client_secret: "${GOOGLE_DRIVE_CLIENT_SECRET}"
